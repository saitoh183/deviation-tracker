{
  "name": "deviation-tracker",
  "version": "2.0.0",
  "description": "Once Human — Deviation Tracker (Desktop)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "rebuild": "electron-builder install-app-deps",
    "postinstall": "npm run rebuild",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.saitoh183.deviation-tracker",
    "productName": "Deviation Tracker",
    "win": {
      "target": ["nsis"],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "**/*",
      "!node_modules/.cache"
    ]
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "express": "^4.21.0",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
